def compute_reward(model_output, task):
    """ARC has a PERFECT reward signal — we can execute and verify."""
    program = extract_program(model_output)
    
    for demo_input, demo_output in task.demos:
        try:
            predicted = execute_safely(program, demo_input)
            if predicted != demo_output:
                return -1.0  # Wrong
        except:
            return -2.0  # Crashed
    
    return +1.0  # All demos matched!
