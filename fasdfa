def solve_task_with_ttt(model, task):
    # Clone model weights
    task_model = clone(model)
    
    # Test-time training on demo pairs
    for epoch in range(100):
        for inp, out in task.demo_pairs:
            loss = task_model.train_step(inp, out)
    
    # Now predict
    prediction = task_model.predict(task.test_input)
    return prediction
