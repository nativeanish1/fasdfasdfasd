# Simplified architecture (Keras/JAX from Book 2)
class ARCModel:
    def __init__(self):
        self.grid_encoder = build_cnn_encoder()      # Book 2, Ch. on CNNs
        self.rule_encoder = build_attention_pooler()   # Book 2, Ch. on Transformers
        self.decoder = build_deconv_decoder()          # Book 2, Ch. on Generative
    
    def forward(self, demo_inputs, demo_outputs, test_input):
        # Encode each demo pair
        rule_vectors = []
        for inp, out in zip(demo_inputs, demo_outputs):
            inp_enc = self.grid_encoder(inp)
            out_enc = self.grid_encoder(out)
            rule_vectors.append(self.rule_encoder(inp_enc, out_enc))
        
        # Aggregate rule (attention over demo pairs)
        rule = aggregate_attention(rule_vectors)
        
        # Decode
        test_enc = self.grid_encoder(test_input)
        output_grid = self.decoder(test_enc, rule)
        return output_grid
